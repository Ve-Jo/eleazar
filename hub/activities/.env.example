# You can use either:
# - hub/.env
# - hub/activities/.env (overrides hub/.env for activities-only local runs)

ACTIVITIES_SERVICE_PORT=3007
ACTIVITY_TUNNEL_PORT=5174

ACTIVITY_CLIENT_ID=""
ACTIVITY_CLIENT_SECRET=""
ACTIVITY_DISCORD_BOT_TOKEN=""
LOCALIZATION_SERVICE_URL="http://localhost:3005"
ACTIVITY_PUBLIC_BASE_URL="https://activities-dev.example.com"
ACTIVITY_REDIRECT_URI="https://activities-dev.example.com/api/auth/discord/callback"
